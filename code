def calculer_indicateurs_techniques(df):
    """
    Calcule les indicateurs techniques pour l'analyse
    
    Indicateurs calculés:
    - SMA (Simple Moving Average): Moyenne mobile simple
    - EMA (Exponential Moving Average): Moyenne mobile exponentielle
    - RSI (Relative Strength Index): Force relative
    - MACD (Moving Average Convergence Divergence)
    - Bollinger Bands: Bandes de Bollinger
    - Volatilité
    """
    
    data = df.copy()
    
    print("Calcul des indicateurs techniques...")
    
    # 1. Moyennes mobiles simples (SMA)
    data['SMA_10'] = data['Close'].rolling(window=10).mean()
    data['SMA_20'] = data['Close'].rolling(window=20).mean()
    data['SMA_50'] = data['Close'].rolling(window=50).mean()
    
    # 2. Moyennes mobiles exponentielles (EMA)
    data['EMA_12'] = data['Close'].ewm(span=12, adjust=False).mean()
    data['EMA_26'] = data['Close'].ewm(span=26, adjust=False).mean()
    
    # 3. MACD (Moving Average Convergence Divergence)
    data['MACD'] = data['EMA_12'] - data['EMA_26']
    data['Signal_Line'] = data['MACD'].ewm(span=9, adjust=False).mean()
    
    # 4. RSI (Relative Strength Index)
    delta = data['Close'].diff()
    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()
    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()
    rs = gain / loss
    data['RSI'] = 100 - (100 / (1 + rs))
    
    # 5. Bandes de Bollinger
    data['BB_Middle'] = data['Close'].rolling(window=20).mean()
    bb_std = data['Close'].rolling(window=20).std()
    data['BB_Upper'] = data['BB_Middle'] + (bb_std * 2)
    data['BB_Lower'] = data['BB_Middle'] - (bb_std * 2)
    
    # 6. Volatilité
    data['Volatility'] = data['Close'].rolling(window=10).std()
    
    # 7. Variation quotidienne
    data['Daily_Return'] = data['Close'].pct_change()
    
    # 8. Volume moyen
    data['Volume_SMA'] = data['Volume'].rolling(window=20).mean()
    
    print(f"   Indicateurs techniques calculés avec succès!")
    print(f"   Nombre de features créées: {len(data.columns)}\n")
    
    return data

# Calculer les indicateurs
df_features = calculer_indicateurs_techniques(df)

