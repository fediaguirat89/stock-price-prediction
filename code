def telecharger_donnees(ticker, periode='2y'):
    """
    Télécharge les données historiques d'une action
    
    Paramètres:
    -----------
    ticker : str
        Symbole de l'action (ex: 'AAPL' pour Apple)
    periode : str
        Période de données ('1y', '2y', '5y', etc.)
    
    Retour:
    -------
    DataFrame avec les données de l'action
    """
    print(f"Téléchargement des données pour {ticker}...")
    
    try:
        # Télécharger avec auto_adjust pour éviter MultiIndex
        data = yf.download(ticker, period=periode, progress=False, auto_adjust=True)
        
        # CORRECTION: Si MultiIndex, aplatir les colonnes
        if isinstance(data.columns, pd.MultiIndex):
            data.columns = data.columns.get_level_values(0)
            print("   Colonnes MultiIndex aplaties")
        
        print(f"   {len(data)} jours de données téléchargés")
        return data
    except Exception as e:
        print(f"   Erreur lors du téléchargement: {e}")
        return None

