def afficher_performances(resultats):
    """Affiche les performances de tous les modèles"""
    
    print("\n" + "="*70)
    print("PERFORMANCES DES MODÈLES")
    print("="*70)
    
    df_perf = pd.DataFrame({
        nom: {
            'RMSE': res['rmse'],
            'MAE': res['mae'],
            'R² Score': res['r2']
        }
        for nom, res in resultats.items()
    }).T
    
    print(df_perf.to_string())
    print("="*70)
    
    # Trouver le meilleur modèle
    meilleur_modele = df_perf['R² Score'].idxmax()
    print(f"\nMeilleur modèle: {meilleur_modele}")
    print(f"R² Score: {df_perf.loc[meilleur_modele, 'R² Score']:.4f}\n")
    
    return df_perf

# Afficher les performances
