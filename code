def visualiser_predictions(y_test, resultats, ticker):
    """Visualise les prédictions vs valeurs réelles"""
    
    print("Création des graphiques de prédictions...")
    
    fig, axes = plt.subplots(2, 1, figsize=(14, 10))
    
    # Graphique 1: Comparaison temporelle
    axes[0].plot(y_test.index, y_test.values, 
                label='Prix réel', linewidth=2, marker='o', markersize=3, color='#2E86DE')
    
    colors = ['#E74C3C', '#2ECC71']
    for idx, (nom_modele, res) in enumerate(resultats.items()):
        axes[0].plot(y_test.index, res['predictions'], 
                    label=f'{nom_modele}', linewidth=2, alpha=0.7, color=colors[idx])
    
    axes[0].set_title(f'Prédictions vs Prix Réel - {ticker}', 
                     fontsize=14, fontweight='bold')
    axes[0].set_xlabel('Date')
    axes[0].set_ylabel('Prix (USD)')
    axes[0].legend()
    axes[0].grid(True, alpha=0.3)
    
    # Graphique 2: Scatter plot pour le meilleur modèle
    meilleur_modele = max(resultats.items(), 
                         key=lambda x: x[1]['r2'])[0]
    y_pred_best = resultats[meilleur_modele]['predictions']
    
    axes[1].scatter(y_test, y_pred_best, alpha=0.5, color='#3498DB')
    axes[1].plot([y_test.min(), y_test.max()], 
                [y_test.min(), y_test.max()], 
                'r--', lw=2, label='Prédiction parfaite')
    axes[1].set_title(f'Précision du modèle {meilleur_modele}', 
                     fontsize=14, fontweight='bold')
    axes[1].set_xlabel('Prix Réel (USD)')
    axes[1].set_ylabel('Prix Prédit (USD)')
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.savefig('images/graphique_predictions.png', dpi=300, bbox_inches='tight')
    plt.show()
    print("   Graphique sauvegardé: images/graphique_predictions.png\n")

# Visualiser les prédictions
visualiser_predictions(y_test, resultats, ticker)

