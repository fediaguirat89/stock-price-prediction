def entrainer_modeles(X_train, X_test, y_train, y_test):
    """
    Entraîne et compare plusieurs modèles de ML
    
    Retour:
    -------
    Dictionnaire avec les modèles entraînés et leurs performances
    """
    
    modeles = {}
    resultats = {}
    
    print("Entraînement des modèles de Machine Learning...\n")
    
    # 1. Régression Linéaire
    print("1. Régression Linéaire...")
    lr = LinearRegression()
    lr.fit(X_train, y_train)
    y_pred_lr = lr.predict(X_test)
    
    modeles['Linear Regression'] = lr
    resultats['Linear Regression'] = {
        'predictions': y_pred_lr,
        'mse': mean_squared_error(y_test, y_pred_lr),
        'rmse': np.sqrt(mean_squared_error(y_test, y_pred_lr)),
        'mae': mean_absolute_error(y_test, y_pred_lr),
        'r2': r2_score(y_test, y_pred_lr)
    }
    print("   Régression Linéaire entraînée\n")
    
    # 2. Random Forest
    print("2. Random Forest...")
    rf = RandomForestRegressor(n_estimators=100, random_state=42, n_jobs=-1)
    rf.fit(X_train, y_train)
    y_pred_rf = rf.predict(X_test)
    
    modeles['Random Forest'] = rf
    resultats['Random Forest'] = {
        'predictions': y_pred_rf,
        'mse': mean_squared_error(y_test, y_pred_rf),
        'rmse': np.sqrt(mean_squared_error(y_test, y_pred_rf)),
        'mae': mean_absolute_error(y_test, y_pred_rf),
        'r2': r2_score(y_test, y_pred_rf)
    }
    print("   Random Forest entraîné\n")
    
    print("Modèles entraînés avec succès!\n")
    
    return modeles, resultats

# Entraîner les modèles
modeles, resultats = entrainer_modeles(X_train, X_test, y_train, y_test)

