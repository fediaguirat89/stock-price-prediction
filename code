def preparer_donnees_ml(df, jours_prediction=1):
    """
    Prépare les données pour le Machine Learning
    
    Paramètres:
    -----------
    df : DataFrame
        Données avec indicateurs techniques
    jours_prediction : int
        Nombre de jours à prédire dans le futur
    
    Retour:
    -------
    X_train, X_test, y_train, y_test, scaler, feature_names
    """
    
    print("Préparation des données pour le Machine Learning...")
    
    # Créer la variable cible (prix à prédire)
    df['Target'] = df['Close'].shift(-jours_prediction)
    
    # Supprimer les lignes avec valeurs manquantes
    df_clean = df.dropna()
    
    # Sélectionner les features pour le modèle
    feature_cols = ['Open', 'High', 'Low', 'Volume',
                   'SMA_10', 'SMA_20', 'SMA_50',
                   'EMA_12', 'EMA_26', 'MACD', 'Signal_Line',
                   'RSI', 'BB_Upper', 'BB_Lower', 'Volatility',
                   'Daily_Return', 'Volume_SMA']
    
    X = df_clean[feature_cols]
    y = df_clean['Target']
    
    # Diviser en ensemble d'entraînement et de test (80/20)
    X_train, X_test, y_train, y_test = train_test_split(
        X, y, test_size=0.2, shuffle=False, random_state=42
    )
    
    # Normalisation des données
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    print(f"   Ensemble d'entraînement: {X_train.shape[0]} échantillons")
    print(f"   Ensemble de test: {X_test.shape[0]} échantillons")
    print(f"   Nombre de features: {X_train.shape[1]}\n")
    
    return X_train_scaled, X_test_scaled, y_train, y_test, scaler, feature_cols

# Préparer les données
X_train, X_test, y_train, y_test, scaler, features = preparer_donnees_ml(df_features)

